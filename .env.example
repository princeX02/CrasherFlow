## Example environment variables for CrusherFlow
# Use these values or create your own local .env and export them before running

# Use Postgres
DB_TYPE=pg

# Connection string (user:password@host:port/dbname)
DATABASE_URL=postgres://crusher:crusherpass@localhost:5432/crusherflow

# For SQLite use (default):
# DB_TYPE=sqlite
# SQLITE_DB=./data.db
