## Example environment variables for CrusherFlow
# Use these values or create your own local .env and export them before running

# Use Postgres
DB_TYPE=pg

# Connection string (user:password@host:port/dbname)
# Local Docker Compose:
DATABASE_URL=postgres://crusher:crusherpass@localhost:5432/crusherflow

# Docker Compose inside containers uses the service hostname:
# DATABASE_URL=postgres://crusher:crusherpass@db:5432/crusherflow

# Render free deployment with a free external Postgres provider (Neon/Supabase):
# DATABASE_URL=postgres://<user>:<password>@<host>/<dbname>?sslmode=require

# JWT secret for signing auth tokens (set in Render environment)
JWT_SECRET=please_set_a_strong_random_value
# Cookie name for auth token (optional)
COOKIE_NAME=crusher_auth

# Admin bootstrap (used by scripts/create_admin.js)
ADMIN_USER=admin
# Set ADMIN_PASS when running the admin creation script locally or via CI
ADMIN_PASS=your_admin_password_here
