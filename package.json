{
  "name": "crusherflow-backend",
  "version": "1.0.0",
  "description": "Simple REST API for CrusherFlow using SQLite",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "init-db": "node init_db.js",
    "create-admin": "node scripts/create_admin.js",
    "check": "node -e \"require('./server')\" || true"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "dotenv": "^16.3.1",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.8.0",
    "winston": "^3.9.0",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.0.0",
    "cookie-parser": "^1.4.6"
  }
}

